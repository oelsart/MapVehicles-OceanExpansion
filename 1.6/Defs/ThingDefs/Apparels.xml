  <ThingDef ParentName="ApparelMakeableBase">
    <defName>MVO_Apparel_SailorShirt</defName>
    <label>sailor shirt</label>
    <description>A simple sailor shirt.</description>
    <recipeMaker>
      <researchPrerequisite>MVO_SailorOutfit</researchPrerequisite>
      <displayPriority>311</displayPriority>
    </recipeMaker>
    <graphicData>
      <texPath>MapVehiclesOcean/Things/Apparel/SailorSuit/Shirt</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>0.9</drawSize>
    </graphicData>
    <costStuffCount>50</costStuffCount>
    <stuffCategories>
      <li>Fabric</li>
    </stuffCategories>
    <thingCategories>
      <li>ApparelMisc</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToMake>2200</WorkToMake>
      <Mass>0.35</Mass>
      <StuffEffectMultiplierArmor>0.2</StuffEffectMultiplierArmor>
      <StuffEffectMultiplierInsulation_Cold>0.30</StuffEffectMultiplierInsulation_Cold>
      <StuffEffectMultiplierInsulation_Heat>0.40</StuffEffectMultiplierInsulation_Heat>
      <EquipDelay>1.2</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <MentalBreakThreshold>-0.03</MentalBreakThreshold>
      <RestRateMultiplier>0.10</RestRateMultiplier>
      <FishingYield>0.05</FishingYield>
    </equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Shoulders</li>
      </bodyPartGroups>
      <wornGraphicPath>MapVehiclesOcean/Things/Apparel/SailorSuit/Shirt</wornGraphicPath>
      <useWornGraphicMask>true</useWornGraphicMask>
      <drawData>
        <defaultData>
          <layer>21</layer>
        </defaultData>
      </drawData>
      <layers>
        <li>OnSkin</li>
      </layers>
      <tags>
        <li>IndustrialBasic</li>
        <li>Western</li>
      </tags>
      <defaultOutfitTags>
        <li>Worker</li>
      </defaultOutfitTags>
    </apparel>
    <tradeTags>
      <li>BasicClothing</li>
    </tradeTags>
  </ThingDef>

