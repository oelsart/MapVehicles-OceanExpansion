          <max>(0.5,0.5,0.5,1)</max>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.9,0.9,0.9,1)</only>
        </li>
      </options>
    </colorGenerator>
    <allowedArchonexusCount>1</allowedArchonexusCount>
    <tradeTags>
      <li>Armor</li>
    </tradeTags>
