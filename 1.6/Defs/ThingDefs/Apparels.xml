    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>MapVehiclesOcean/Things/ZiplineBelt/ZiplineBelt_south</texPath>
    </graphicData>
    <techLevel>Medieval</techLevel>
    <statBases>
      <Mass>1</Mass>
