          <offset>(-0.025,-0.3)</offset>
          <scale>0.45</scale>
          <thin>
            <offset>(-0.05,0)</offset>
          </thin>
          <female>
            <offset>(-0.05,0)</offset>
          </female>
          <hulk>
            <offset>(-0.05,-0.15)</offset>
          </hulk>
        </east>
        <west>
          <offset>(0.025,-0.3)</offset>
          <scale>0.45</scale>
          <thin>
            <offset>(0.05,0)</offset>
          </thin>
          <female>
            <offset>(0.05,0)</offset>
          </female>
          <hulk>
            <offset>(0.05,-0.15)</offset>
          </hulk>
