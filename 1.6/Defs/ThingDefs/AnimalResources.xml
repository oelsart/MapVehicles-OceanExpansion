<Defs>

  <ThingDef ParentName="OrganicProductBase">
    <defName>Meat_MVO_Shark_Prepped</defName>
    <label>prepped shark meat</label>
    <graphicData>
      <graphicClass>Graphic_StackCount</graphicClass>
      <texPath>Things/Item/Resource/MeatFoodRaw/Meat_Big</texPath>
    </graphicData>
    <thingCategories>
      <li>MeatRaw</li>
    </thingCategories>
    <statBases>
      <Flammability>0.5</Flammability>
      <Nutrition>0.05</Nutrition>
      <FoodPoisonChanceFixedHuman>0.02</FoodPoisonChanceFixedHuman>
      <MarketValue>2</MarketValue>
    </statBases>
    <socialPropernessMatters>true</socialPropernessMatters>
    <ingestible>
      <parent>Meat_MVO_Shark_Prepped</parent>
      <foodType>Meat</foodType>
      <preferability>RawBad</preferability>
      <tasteThought>AteRawFood</tasteThought>
      <ingestEffect>EatMeat</ingestEffect>
      <ingestSound>RawMeat_Eat</ingestSound>
      <sourceDef>MVO_Shark</sourceDef>
    </ingestible>
    <comps>
      <li Class="CompProperties_Rottable">
        <rotDestroys>true</rotDestroys>
      </li>
      <li MayRequire="Ludeon.RimWorld.Anomaly">
        <compClass>CompHarbingerTreeConsumable</compClass>
      </li>
    </comps>
  </ThingDef>

